{
	"name": "docs",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"db:generate": "bunx --bun auth@latest generate -y",
		"db:migrate": "bunx --bun auth@latest migrate -y",
		"build": "bun --bun next build",
		"postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
		"dev": "bun --bun next dev --hostname 0.0.0.0 --port 3000",
		"lint": "eslint",
		"start": "bun --bun next start --hostname 0.0.0.0 --port 3000"
	},
	"dependencies": {
		"@iconify-react/basil": "^1.0.2",
		"@iconify-react/material-icon-theme": "^1.0.13",
		"@iconify-react/mdi": "^1.0.2",
		"@iconify-react/simple-icons": "^1.0.13",
		"@iconify-react/skill-icons": "^1.0.2",
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.6",
		"@theguild/remark-mermaid": "^0.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"better-auth": "^1.6.11",
		"better-sqlite3": "^12.10.0",
		"next": "^16.2.6",
		"nextra": "4.5.0",
		"nextra-theme-docs": "4.5.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"sass": "^1.99.0",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@types/bun": "^1.3.14",
		"@types/node": "^20.19.41",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "^9.39.4",
		"eslint-config-next": "16.2.6",
		"pagefind": "^1.5.2"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"better-sqlite3",
		"better-auth",
		"sharp",
		"unrs-resolver"
	]
}
